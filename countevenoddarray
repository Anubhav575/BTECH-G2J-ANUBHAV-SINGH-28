#include <stdio.h>

int main() {
    int n, i, a[50], evenCount = 0, oddCount = 0;

    printf("Enter number of elements: ");
    scanf("%d", &n);

    printf("Enter %d elements:\n", n);
    for(i = 0; i < n; i++) {
        scanf("%d", &a[i]);

        
        if(a[i] % 2 == 0) {
            evenCount++;
        } else {
            oddCount++;
        }
    }

    printf("\nTotal Even elements: %d", evenCount);
    printf("\nTotal Odd elements: %d", oddCount);
    return 0;
}
    
